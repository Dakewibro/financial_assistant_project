PORT=4000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority&appName=<app-name>
MONGODB_DB=financial_assistant
STORAGE_MODE=mongo
# Required on Vercel/production (VERCEL=1 or NODE_ENV=production). Use a long random string, not the dev default.
JWT_SECRET=<long-random-secret>
ADMIN_API_TOKEN=<set-a-secret-for-import-and-test-data-endpoints>
# Clients send the same value in header x-admin-token (alias: admin-token). Stored value is trimmed/BOM-stripped; see utils/adminToken.ts for client-side normalization.
ALLOWED_ORIGINS=http://localhost:5173,https://<your-frontend>.vercel.app,https://*.vercel.app
# On Vercel/production, auth defaults to enforced unless AUTH_ENFORCED=false. For local dev, omit or set false.
# AUTH_ENFORCED=false
# Demo load/clear/seed: defaults on (logged-in users may run them). Set false to require x-admin-token for demo routes.
# DEMO_MUTATIONS_ENABLED=false
